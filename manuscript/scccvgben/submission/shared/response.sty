%% response.sty — polished macros for cover letter and rebuttal letters
%% Three semantic blocks: reviewer comment / authors' response / revised text.
%% Typography: newtxtext serif body + Helvetica sans headings.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{response}[2026/04/28 v3.0 Reviewer response macros]

%% --- Core packages ---------------------------------------------------------
\RequirePackage{mdframed}
\RequirePackage{xcolor}
\RequirePackage{ragged2e}
\RequirePackage{newtxtext}        % Times New Roman-style serif body
\RequirePackage[T1]{fontenc}
\RequirePackage{helvet}           % Helvetica sans for headings
\RequirePackage{titlesec}
\RequirePackage{fancyhdr}
\RequirePackage{geometry}

%% --- Refined colour palette ------------------------------------------------
%%   Reviewer comment : professional gray   (#6b7280 / #f9fafb / #374151)
%%   Authors' response: deep cyan-teal      (#0e7490 / #ecfeff / #0e7490)
%%   Revised text     : forest green        (#15803d / #f0fdf4 / #15803d)
\definecolor{rcborder} {HTML}{6b7280}
\definecolor{rcbg}     {HTML}{f9fafb}
\definecolor{rcheader} {HTML}{374151}
\definecolor{rrborder} {HTML}{0e7490}
\definecolor{rrbg}     {HTML}{ecfeff}
\definecolor{rrheader} {HTML}{0e7490}
\definecolor{rxborder} {HTML}{15803d}
\definecolor{rxbg}     {HTML}{f0fdf4}
\definecolor{rxheader} {HTML}{15803d}

%% --- Section heading style -------------------------------------------------
%%   \section* renders in Helvetica bold teal with a rule below
\titleformat{\section}[hang]
  {\sffamily\bfseries\large\color{rrheader}}
  {}
  {0pt}
  {}
  [\vspace{2pt}\textcolor{rrheader}{\titlerule[0.6pt]}]

%% --- Reviewer comment box --------------------------------------------------
\mdfdefinestyle{rcommentstyle}{%
  linecolor=rcborder,
  linewidth=0.5pt,
  backgroundcolor=rcbg,
  roundcorner=5pt,
  innertopmargin=10pt,
  innerbottommargin=10pt,
  innerleftmargin=14pt,
  innerrightmargin=14pt,
  skipabove=6pt,
  skipbelow=8pt,
  shadow=true,
  shadowsize=1.5pt,
  shadowcolor=black!12,
  frametitlerule=true,
  frametitlerulewidth=0.5pt,
  frametitlerulecolor=rcborder,
  frametitlebackgroundcolor=rcheader,
  frametitlefont={\small\sffamily\bfseries\color{white}},
  frametitle={\strut\enspace Reviewer comment\enspace},
  frametitleaboveskip=3pt,
  frametitlebelowskip=3pt,
}
\newcommand{\rcomment}[1]{%
  \begin{mdframed}[style=rcommentstyle]%
    \itshape #1%
  \end{mdframed}%
}

%% --- Authors' response box -------------------------------------------------
\mdfdefinestyle{rresponsestyle}{%
  linecolor=rrborder,
  linewidth=0.7pt,
  backgroundcolor=rrbg,
  roundcorner=5pt,
  innertopmargin=10pt,
  innerbottommargin=10pt,
  innerleftmargin=14pt,
  innerrightmargin=14pt,
  skipabove=6pt,
  skipbelow=8pt,
  shadow=true,
  shadowsize=1.5pt,
  shadowcolor=black!12,
  frametitlerule=true,
  frametitlerulewidth=0.7pt,
  frametitlerulecolor=rrborder,
  frametitlebackgroundcolor=rrheader,
  frametitlefont={\small\sffamily\bfseries\color{white}},
  frametitle={\strut\enspace Authors' response\enspace},
  frametitleaboveskip=3pt,
  frametitlebelowskip=3pt,
}
\newcommand{\rresponse}[1]{%
  \begin{mdframed}[style=rresponsestyle]%
    #1%
  \end{mdframed}%
}

%% --- Revised manuscript text box -------------------------------------------
\mdfdefinestyle{rchangestyle}{%
  linecolor=rxborder,
  linewidth=0.7pt,
  backgroundcolor=rxbg,
  roundcorner=5pt,
  innertopmargin=10pt,
  innerbottommargin=10pt,
  innerleftmargin=14pt,
  innerrightmargin=14pt,
  skipabove=6pt,
  skipbelow=8pt,
  shadow=true,
  shadowsize=1.5pt,
  shadowcolor=black!12,
  frametitlerule=true,
  frametitlerulewidth=0.7pt,
  frametitlerulecolor=rxborder,
  frametitlebackgroundcolor=rxheader,
  frametitlefont={\small\sffamily\bfseries\color{white}},
  frametitle={\strut\enspace Revised manuscript text\enspace},
  frametitleaboveskip=3pt,
  frametitlebelowskip=3pt,
}
\newcommand{\rchange}[1]{%
  \begin{mdframed}[style=rchangestyle]%
    #1%
  \end{mdframed}%
}

%% --- Rebuttal section callout ----------------------------------------------
%%   \reviewersection{R1.1 --- Title} renders a full-width solid teal bar
%%   with white sans-serif text; use instead of bare \section* in rebuttals.
\newcommand{\reviewersection}[1]{%
  \bigskip
  \noindent
  \colorbox{rrheader}{%
    \parbox{\dimexpr\linewidth-2\fboxsep\relax}{%
      \vspace{4pt}%
      \hspace{6pt}{\sffamily\bfseries\color{white}\large #1}%
      \vspace{4pt}%
    }%
  }%
  \vspace{6pt}%
  \par
}

\endinput
